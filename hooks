				;;
		esac
	fi

	echo "$LINE"

	LINE=`sed -e 's/  */ /g' -e 's/^ *//' <(echo "$LINE")`

	PERSON=`echo "$LINE" | gcut -d ' ' -f 1 | tr -cd "[[:alnum:]]"`
	COMMAND=`gcut -d ' ' -f 2 <(echo "$LINE")`
	EXTRA=`echo "$LINE" | gcut -d ' ' -f 1,2 --complement`

	echo "$PERSON ordered $COMMAND - $EXTRA"

	case "$COMMAND" in
		chat)
			echo Attempting to chat
			chat "$EXTRA" "$PERSON"
